# =============================================================================
# Global Gitignore - Whitelist-Ready Template
# =============================================================================
# Usage:
#   1. Global: Keep as-is, blocks everything by default
#   2. Per-project: Copy to project, remove the "# MASTER BLOCK" section,
#      then add whitelist rules with "!" prefix
#
# Example whitelist for a Node.js project:
#   !*.js
#   !*.ts
#   !*.json
#   !*.md
#   !*/
# =============================================================================

# =============================================================================
# Operating Systems
# =============================================================================

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
._*
.fseventsd
.TemporaryItems
.DocumentRevisions-V100
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.stackdump
*.lnk

# Linux
.directory
.Trash-*
.nfs*

